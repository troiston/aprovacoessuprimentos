# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/mydb?schema=public"

# Seed (prisma/seed.ts) — senha inicial do usuário admin (acesso@digaola.com)
# SEED_ADMIN_PASSWORD="sua-senha-segura"

# Playwright E2E — igual à senha do seed após `prisma db seed` (ou defina só E2E_PASSWORD)
# E2E_PASSWORD="sua-senha-segura"

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="VibeCoding SaaS"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Auth (Better Auth)
BETTER_AUTH_SECRET="your-secret-here-min-16-chars"
BETTER_AUTH_URL="http://localhost:3000"

# Cifragem de definições sensíveis (SMTP, etc.) — 32 bytes em hex (64 chars) ou base64
# SETTINGS_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Optional: Supabase (uncomment if using)
# NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
